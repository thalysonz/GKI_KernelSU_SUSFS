+/*
+ * Hide Frida-related VMAs from /proc/self/maps and /proc/self/smaps
+ *
+ * Note: d_iname contains only the filename, not the full path.
+ * e.g. for /data/local/tmp/frida-server, d_iname = "frida-server"
+ */
+static int bypass_show_map_vma(struct vm_area_struct *vma)
+{
+	struct file *file = vma->vm_file;
+	const char *name;
+
+	if (!file || !file->f_path.dentry)
+		return 0;
+
+	name = file->f_path.dentry->d_iname;
+
+	/* Frida binaries and libraries */
+	if (strstr(name, "frida-") ||
+	    strstr(name, "frida_") ||
+	    strstr(name, "linjector"))
+		return 1;
+
+	/* libart.so with exec permission - Frida modifies it in memory */
+	if (strstr(name, "libart.so") && (vma->vm_flags & VM_EXEC))
+		return 1;
+
+	/* memfd used by Frida JIT */
+	if (strstr(name, "jit-cache") ||
+	    strstr(name, "jit-zygote"))
+		return 1;
+
+	return 0;
+}
+
 /*
  * Indicate if the VMA is a stack for the given task; for
  * /proc/PID/maps that is the stack of the main task.
@@ -348,6 +380,9 @@ show_map_vma(struct seq_file *m, struct vm_area_struct *vma)
 	dev_t dev = 0;
 	const char *name = NULL;
 
+	if (bypass_show_map_vma(vma))
+		return;
+
 	if (file) {
 		struct inode *inode = file_inode(vma->vm_file);
 		dev = inode->i_sb->s_dev;
